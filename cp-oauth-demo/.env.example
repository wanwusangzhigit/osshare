# CP OAuth Configuration
# Get these from https://www.cpoauth.com/ developer settings

# Your application client ID
CLIENT_ID=your_client_id_here

# Your application client secret (keep this secure!)
CLIENT_SECRET=your_client_secret_here

# The redirect URI registered in your CP OAuth application settings
# Must match exactly what you configured in the CP OAuth dashboard
REDIRECT_URI=http://localhost:13450/callback

# Server port
PORT=13450
